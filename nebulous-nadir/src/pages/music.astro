---
import Layout from '../layouts/Layout.astro';
import { sectionUrl } from '../lib/paths';

const base = import.meta.env.BASE_URL;
---

<Layout title="Music" description="Music — Spencerprod portfolio.">
	<p class="section-eyebrow">Music</p>
	<h1>Sound and releases</h1>
	<p class="section-lede">
		Share EPs, mixes, and what you are building in the DAW. The blocks below are stand-ins for artwork, players, and credits.
	</p>

	<p class="ph-callout">
		<strong>Placeholder content.</strong> Embed Bandcamp, SoundCloud, or Spotify iframes here, or link out to streaming pages.
		<span class="music-blog-prompt">
			For opinions on albums, singles, and EPs—see the <a href={sectionUrl(base, 'music/blog')}>music blog</a>.
		</span>
	</p>

	<h2 class="ph-block-title">Releases</h2>
	<div class="ph-row">
		<div class="ph-visual ph-visual--square" aria-hidden="true"></div>
		<div class="ph-row-body">
			<h3>Untitled EP — 2026</h3>
			<p>Track list, genre, and one sentence about how it was made. Add cover art image when you have assets.</p>
		</div>
	</div>
	<div class="ph-row">
		<div class="ph-visual ph-visual--square" aria-hidden="true"></div>
		<div class="ph-row-body">
			<h3>Live set recording</h3>
			<p>Placeholder for a mix or show notes: venue, date, gear list, or link to a full recording.</p>
		</div>
	</div>

	<h2 class="ph-block-title">Now listening</h2>
	<ul class="ph-list">
		<li>Album or artist you want to shout out</li>
		<li>Playlist theme (e.g. late-night production, focus)</li>
		<li>Gear or plugins you are experimenting with</li>
	</ul>
</Layout>

<style>
	.music-blog-prompt {
		display: block;
		margin-top: 0.75rem;
		padding-top: 0.75rem;
		border-top: 1px solid var(--border);
	}
</style>
