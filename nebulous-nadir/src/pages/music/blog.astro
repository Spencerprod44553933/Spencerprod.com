---
import Layout from '../../layouts/Layout.astro';
import { sectionUrl } from '../../lib/paths';
import {
	pillLabels,
	reviewIntro,
	reviewPullquote,
	reviewTracks,
	reviewUi,
	reviewVerdict,
	type ReviewTrack,
} from '../../data/dinastia-review-i18n';

const base = import.meta.env.BASE_URL;
const standardTracks = reviewTracks.filter((t) => t.tier !== 'deluxe');
const deluxeTracks = reviewTracks.filter((t) => t.tier === 'deluxe');
const splitAt = standardTracks.findIndex((t) => t.name === 'Malibu');
const standardBeforePull = splitAt === -1 ? standardTracks : standardTracks.slice(0, splitAt);
const standardAfterPull = splitAt === -1 ? [] : standardTracks.slice(splitAt);

function tierClass(tier: ReviewTrack['tier']): string {
	return `mb-track--${tier}`;
}

function pillClass(pill: NonNullable<ReviewTrack['pill']>): string {
	if (pill === 'standout') return 'mb-pill--standout';
	if (pill === 'deep') return 'mb-pill--deep';
	if (pill === 'favorite') return 'mb-pill--favorite';
	return 'mb-pill--deluxe';
}
---

<Layout title={reviewUi.en.pageTitle} description={reviewUi.en.description}>
	<link
		slot="head-extra"
		rel="stylesheet"
		href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,800;1,400;1,600;1,700&family=Source+Serif+4:opsz,wght@8..60,300;8..60,400&display=swap"
	/>

	<script
		is:inline
		define:vars={{
			titleEn: reviewUi.en.pageTitle,
			titleEs: reviewUi.es.pageTitle,
			descEn: reviewUi.en.description,
			descEs: reviewUi.es.description,
		}}
	>
		(function () {
			var suffix = ' · Spencerprod';
			function setDocLang(lang) {
				document.title = (lang === 'es' ? titleEs : titleEn) + suffix;
				var m = document.querySelector('meta[name="description"]');
				if (m) m.setAttribute('content', lang === 'es' ? descEs : descEn);
			}
			window.addEventListener('site-lang-change', function (e) {
				if (e.detail && e.detail.lang) setDocLang(e.detail.lang);
			});
			setDocLang(document.documentElement.getAttribute('data-site-lang') || 'en');
		})();
	</script>

	<p class="section-eyebrow">
		<span class="i18n-en">{reviewUi.en.eyebrow}</span>
		<span class="i18n-es">{reviewUi.es.eyebrow}</span>
	</p>
	<h1 class="mb-page-title">
		<span class="i18n-en">{reviewUi.en.h1}</span>
		<span class="i18n-es">{reviewUi.es.h1}</span>
	</h1>
	<p class="section-lede">
		<span class="i18n-en">{reviewUi.en.lede}</span>
		<span class="i18n-es">{reviewUi.es.lede}</span>
	</p>

	<article class="mb-review" aria-label="Album review: Dinastía">
		<p class="mb-meta">
			<span class="i18n-en">{reviewUi.en.meta}</span>
			<span class="i18n-es">{reviewUi.es.meta}</span>
		</p>

		<header class="mb-hero">
			<p class="mb-kicker">
				<span class="i18n-en">{reviewUi.en.kicker}</span>
				<span class="i18n-es">{reviewUi.es.kicker}</span>
			</p>
			<h2 class="mb-album-title">Dinastía</h2>
			<p class="mb-artists">Peso Pluma &amp; Tito Doble P</p>
			<div class="mb-rating-row">
				<span class="mb-stars">
					<span class="i18n-en" aria-label={reviewUi.en.starsAria}>★★★★★</span>
					<span class="i18n-es" aria-label={reviewUi.es.starsAria}>★★★★★</span>
				</span>
				<span class="mb-essential-label">
					<span class="i18n-en">{reviewUi.en.essential}</span>
					<span class="i18n-es">{reviewUi.es.essential}</span>
				</span>
			</div>
		</header>

		<div class="mb-prose">
			<p>
				<span class="i18n-en">{reviewIntro.en[0]}</span>
				<span class="i18n-es">{reviewIntro.es[0]}</span>
			</p>
			<p>
				<span class="i18n-en">{reviewIntro.en[1]}</span>
				<span class="i18n-es">{reviewIntro.es[1]}</span>
			</p>
		</div>

		<h3 class="mb-section-head">
			<span class="i18n-en">{reviewUi.en.sectionStandard}</span>
			<span class="i18n-es">{reviewUi.es.sectionStandard}</span>
		</h3>

		{
			standardBeforePull.map((track) => (
				<section class:list={['mb-track', tierClass(track.tier)]}>
					<div class="mb-track-head">
						<h4 class="mb-track-name">{track.name}</h4>
						{track.pill ? (
							<span class:list={['mb-pill', pillClass(track.pill)]}>
								<span class="i18n-en">{pillLabels.en[track.pill]}</span>
								<span class="i18n-es">{pillLabels.es[track.pill]}</span>
							</span>
						) : null}
					</div>
					{track.richText ? (
						<p>
							<span class="i18n-en" set:html={track.en} />
							<span class="i18n-es" set:html={track.es} />
						</p>
					) : (
						<p>
							<span class="i18n-en">{track.en}</span>
							<span class="i18n-es">{track.es}</span>
						</p>
					)}
				</section>
			))
		}

		<blockquote class="mb-pullquote">
			<p>
				<span class="i18n-en">{reviewPullquote.en}</span>
				<span class="i18n-es">{reviewPullquote.es}</span>
			</p>
		</blockquote>

		{
			standardAfterPull.map((track) => (
				<section class:list={['mb-track', tierClass(track.tier)]}>
					<div class="mb-track-head">
						<h4 class="mb-track-name">{track.name}</h4>
						{track.pill ? (
							<span class:list={['mb-pill', pillClass(track.pill)]}>
								<span class="i18n-en">{pillLabels.en[track.pill]}</span>
								<span class="i18n-es">{pillLabels.es[track.pill]}</span>
							</span>
						) : null}
					</div>
					{track.richText ? (
						<p>
							<span class="i18n-en" set:html={track.en} />
							<span class="i18n-es" set:html={track.es} />
						</p>
					) : (
						<p>
							<span class="i18n-en">{track.en}</span>
							<span class="i18n-es">{track.es}</span>
						</p>
					)}
				</section>
			))
		}

		<div class="mb-rule" role="separator">
			<span class="mb-rule-line" aria-hidden="true" />
			<span class="mb-rule-label">
				<span class="i18n-en">{reviewUi.en.ruleDeluxe}</span>
				<span class="i18n-es">{reviewUi.es.ruleDeluxe}</span>
			</span>
			<span class="mb-rule-line" aria-hidden="true" />
		</div>

		{
			deluxeTracks.map((track) => (
				<section class:list={['mb-track', tierClass(track.tier)]}>
					<div class="mb-track-head">
						<h4 class="mb-track-name">{track.name}</h4>
						{track.pill ? (
							<span class:list={['mb-pill', pillClass(track.pill)]}>
								<span class="i18n-en">{pillLabels.en[track.pill]}</span>
								<span class="i18n-es">{pillLabels.es[track.pill]}</span>
							</span>
						) : null}
					</div>
					{track.richText ? (
						<p>
							<span class="i18n-en" set:html={track.en} />
							<span class="i18n-es" set:html={track.es} />
						</p>
					) : (
						<p>
							<span class="i18n-en">{track.en}</span>
							<span class="i18n-es">{track.es}</span>
						</p>
					)}
				</section>
			))
		}

		<div class="mb-verdict">
			<p class="mb-verdict-label">
				<span class="i18n-en">{reviewUi.en.verdictLabel}</span>
				<span class="i18n-es">{reviewUi.es.verdictLabel}</span>
			</p>
			<p class="mb-verdict-text">
				<span class="i18n-en">{reviewVerdict.en}</span>
				<span class="i18n-es">{reviewVerdict.es}</span>
			</p>
		</div>

		<p class="mb-back">
			<a href={sectionUrl(base, 'music')}>
				<span class="i18n-en">{reviewUi.en.backLink}</span>
				<span class="i18n-es">{reviewUi.es.backLink}</span>
			</a>
		</p>
	</article>
</Layout>

<style>
	/* Editorial review: Playfair Display + Source Serif 4; scoped to this page via .mb-review + .mb-page-title */
	.mb-page-title {
		font-family: var(--font-display);
	}

	.mb-review {
		--mr-playfair: 'Playfair Display', Georgia, 'Times New Roman', serif;
		--mr-serif: 'Source Serif 4', 'Source Serif Pro', Georgia, serif;
		--mr-text: var(--text);
		--mr-muted: color-mix(in srgb, var(--text) 48%, var(--bg));
		--mr-faint: color-mix(in srgb, var(--text) 22%, var(--bg));
		--mr-hairline: color-mix(in srgb, var(--text) 32%, transparent);
		--mr-border-muted: color-mix(in srgb, var(--text) 18%, var(--bg));
		--mr-border-strong: color-mix(in srgb, var(--text) 72%, var(--bg));
		--mr-favorite: #9b7fa6;
		--mr-favorite-dim: color-mix(in srgb, #9b7fa6 18%, var(--bg));
		--mr-amber: #c17f3a;
		--mr-amber-surface: color-mix(in srgb, #c17f3a 14%, var(--bg));
		--mr-pill-standout-bg: var(--surface);
		--mr-pill-standout-border: color-mix(in srgb, var(--text) 14%, var(--bg));
		--mr-verdict-fill: color-mix(in srgb, var(--surface) 92%, var(--bg));

		max-width: 38rem;
		margin-top: 1.25rem;
		padding-bottom: 3rem;
		background: transparent;
	}

	@media (prefers-color-scheme: dark) {
		.mb-review {
			--mr-verdict-fill: color-mix(in srgb, var(--text) 6%, var(--bg));
			--mr-pill-standout-bg: color-mix(in srgb, var(--text) 8%, var(--bg));
			--mr-pill-standout-border: color-mix(in srgb, var(--text) 20%, var(--bg));
		}
	}

	.mb-meta {
		font-family: var(--mr-serif);
		font-weight: 300;
		font-size: 0.8125rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--mr-muted);
		margin: 0 0 1.25rem;
	}

	.mb-hero {
		border-top: 2.5px solid var(--mr-text);
		padding-top: 1.5rem;
		margin-bottom: 0;
	}

	.mb-kicker {
		font-family: var(--mr-playfair);
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--mr-muted);
		margin: 0 0 0.75rem;
	}

	.mb-album-title {
		font-family: var(--mr-playfair);
		font-size: clamp(2.25rem, 6vw, 3rem);
		font-weight: 800;
		letter-spacing: -0.02em;
		line-height: 1.05;
		margin: 0 0 0.5rem;
		color: var(--mr-text);
	}

	.mb-artists {
		font-family: var(--mr-playfair);
		font-size: clamp(1.05rem, 2.5vw, 1.2rem);
		font-style: italic;
		font-weight: 400;
		margin: 0 0 1.25rem;
		color: var(--mr-muted);
	}

	.mb-rating-row {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.65rem 1rem;
		padding-bottom: 1.25rem;
		border-bottom: 0.5px solid var(--mr-hairline);
		margin-bottom: 1.75rem;
	}

	.mb-stars {
		font-family: var(--mr-playfair);
		font-size: 1.125rem;
		letter-spacing: 0.12em;
		line-height: 1;
		color: var(--mr-text);
	}

	.mb-essential-label {
		font-family: var(--mr-serif);
		font-size: 0.6875rem;
		font-weight: 300;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--mr-muted);
	}

	.mb-prose p,
	.mb-track p,
	.mb-verdict-text {
		font-family: var(--mr-serif);
		font-weight: 300;
		font-size: 1.0625rem;
		line-height: 1.72;
		margin: 0 0 1.15rem;
		color: var(--mr-text);
	}

	.mb-em {
		font-family: var(--mr-playfair);
		font-style: italic;
		font-weight: 400;
	}

	.mb-section-head {
		font-family: var(--mr-playfair);
		font-size: 1.35rem;
		font-weight: 700;
		letter-spacing: -0.02em;
		margin: 2.5rem 0 1.25rem;
		color: var(--mr-text);
	}

	.mb-track {
		margin-bottom: 1.35rem;
		padding: 1.1rem 1.15rem 1.1rem 1.25rem;
		border-left: 2px solid var(--mr-border-muted);
		background: transparent;
	}

	.mb-track--muted {
		border-left-color: var(--mr-border-muted);
	}

	.mb-track--standout {
		border-left-color: var(--mr-border-strong);
	}

	.mb-track--deep {
		border-left-color: var(--mr-faint);
	}

	.mb-track--favorite {
		border-left-color: var(--mr-favorite);
	}

	.mb-track--deluxe {
		border-left-color: var(--mr-amber);
	}

	.mb-track-head {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem 0.75rem;
		margin-bottom: 0.6rem;
	}

	.mb-track-name {
		font-family: var(--mr-playfair);
		font-size: 1.125rem;
		font-weight: 700;
		letter-spacing: -0.02em;
		margin: 0;
		color: var(--mr-text);
		flex: 1 1 auto;
		min-width: 0;
	}

	.mb-pill {
		font-family: var(--mr-serif);
		font-size: 0.625rem;
		font-weight: 400;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		padding: 0.35rem 0.65rem;
		border-radius: 999px;
		flex-shrink: 1;
		min-width: 0;
		max-width: 13rem;
		text-align: center;
		line-height: 1.35;
		hyphens: auto;
	}

	.mb-pill--favorite {
		background: var(--mr-favorite-dim);
		color: color-mix(in srgb, var(--mr-favorite) 55%, var(--text));
		border: 1px solid color-mix(in srgb, var(--mr-favorite) 35%, transparent);
	}

	.mb-pill--standout {
		background: var(--mr-pill-standout-bg);
		color: var(--mr-text);
		border: 1px solid var(--mr-pill-standout-border);
	}

	.mb-pill--deep {
		background: transparent;
		color: var(--mr-muted);
		border: 1px solid var(--mr-faint);
		opacity: 0.92;
	}

	.mb-pill--deluxe {
		background: var(--mr-amber-surface);
		color: color-mix(in srgb, var(--mr-amber) 45%, var(--text));
		border: 1px solid color-mix(in srgb, var(--mr-amber) 40%, transparent);
	}

	.mb-pullquote {
		margin: 2.5rem 0;
		padding: 1.35rem 1rem;
		text-align: center;
		border-top: 0.5px solid var(--mr-hairline);
		border-bottom: 0.5px solid var(--mr-hairline);
		background: transparent;
	}

	.mb-pullquote p {
		font-family: var(--mr-playfair);
		font-size: 1.25rem;
		font-style: italic;
		font-weight: 400;
		line-height: 1.45;
		margin: 0;
		color: var(--mr-text);
	}

	.mb-rule {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin: 3rem 0 2rem;
		width: 100%;
	}

	.mb-rule-line {
		flex: 1;
		height: 0.5px;
		background: var(--mr-hairline);
		min-width: 1.5rem;
	}

	.mb-rule-label {
		font-family: var(--mr-serif);
		font-size: 0.6875rem;
		font-weight: 300;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--mr-muted);
		white-space: nowrap;
	}

	.mb-verdict {
		margin-top: 2.75rem;
		padding: 1.35rem 1.5rem 1.5rem;
		border-radius: 10px;
		border: 0.5px solid var(--mr-hairline);
		background: var(--mr-verdict-fill);
	}

	.mb-verdict-label {
		font-family: var(--mr-serif);
		font-size: 0.6875rem;
		font-weight: 300;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--mr-muted);
		margin: 0 0 0.85rem;
	}

	.mb-verdict-text {
		margin: 0;
	}

	.mb-back {
		margin-top: 2.75rem;
		padding-top: 1.5rem;
		border-top: 0.5px solid var(--mr-hairline);
		font-family: var(--mr-serif);
		font-weight: 300;
		font-size: 0.9375rem;
	}

	.mb-back a {
		color: var(--text);
		font-weight: 400;
	}
</style>
