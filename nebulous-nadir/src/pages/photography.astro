---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Photography" description="The world as I catch it. — Spencerprod.">
	<p class="section-eyebrow">Photography</p>
	<h1>Photography</h1>
	<p class="section-lede">The world as I catch it.</p>

	<p class="ph-callout">
		<strong>Placeholder grid.</strong> Put files in <code>src/assets/photos/</code> (or similar), then map over them or hand-place each shot with alt text.
	</p>

	<h2 class="ph-block-title">Selected work</h2>
	<div class="ph-grid">
		<figure class="ph-card">
			<div class="ph-visual ph-visual--square" aria-hidden="true"></div>
			<figcaption class="ph-caption">Street — morning light</figcaption>
		</figure>
		<figure class="ph-card">
			<div class="ph-visual ph-visual--square" aria-hidden="true"></div>
			<figcaption class="ph-caption">Portrait study</figcaption>
		</figure>
		<figure class="ph-card">
			<div class="ph-visual ph-visual--square" aria-hidden="true"></div>
			<figcaption class="ph-caption">Landscape, 35mm</figcaption>
		</figure>
		<figure class="ph-card">
			<div class="ph-visual ph-visual--square" aria-hidden="true"></div>
			<figcaption class="ph-caption">Event / crowd</figcaption>
		</figure>
		<figure class="ph-card">
			<div class="ph-visual ph-visual--square" aria-hidden="true"></div>
			<figcaption class="ph-caption">Still life</figcaption>
		</figure>
		<figure class="ph-card">
			<div class="ph-visual ph-visual--square" aria-hidden="true"></div>
			<figcaption class="ph-caption">Night exposure</figcaption>
		</figure>
	</div>
</Layout>
