---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Photography" description="Photography — Spencerprod portfolio.">
	<p class="eyebrow">Photography</p>
	<h1>Frames and light</h1>
	<p class="section-lede">
		Add image grids or galleries below. For performance, use Astro’s <code>Image</code> component with optimized assets
		when you drop in real photos.
	</p>

	<section class="content-block">
		<h2>Gallery</h2>
		<p>Placeholder for your photography grid. Consider a simple CSS grid of thumbnails linking to larger views.</p>
	</section>
</Layout>

<style>
	.eyebrow {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		font-weight: 500;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--accent);
		margin: 0 0 0.75rem;
	}

	.content-block {
		margin-top: 2rem;
		padding: 1.5rem;
		border-radius: 10px;
		border: 1px solid var(--border);
		background: color-mix(in srgb, var(--surface) 75%, transparent);
	}

	.content-block h2 {
		margin-top: 0;
	}

	code {
		font-family: var(--font-mono);
		font-size: 0.9em;
		padding: 0.1em 0.35em;
		border-radius: 4px;
		background: color-mix(in srgb, var(--accent) 15%, var(--surface));
		color: var(--text);
	}
</style>
