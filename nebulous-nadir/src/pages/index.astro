---
import Layout from '../layouts/Layout.astro';
import { sectionUrl } from '../lib/paths';

const base = import.meta.env.BASE_URL;
---

<Layout
	title="Spencerprod"
	description="Many things. One site — cyber projects, original music, sports rants, photography, and opinions."
>
	<section class="hero">
		<h1>Many things. One site</h1>
		<p class="section-lede">
			Cyber projects, original music, sports rants, photography, and opinions I’ll stand behind.
		</p>
	</section>

	<section class="grid">
		<a class="card" href={sectionUrl(base, 'cyber')}>
			<span class="card-label">01</span>
			<h2>Cyber</h2>
			<p>Here’s what I’ve been breaking and building.</p>
		</a>
		<a class="card" href={sectionUrl(base, 'music')}>
			<span class="card-label">02</span>
			<h2>My Music</h2>
			<p>Songs I made in my bedroom at weird hours.</p>
		</a>
		<a class="card" href={sectionUrl(base, 'music/blog')}>
			<span class="card-label">03</span>
			<h2>Music blog</h2>
			<p>Hot takes. Correct takes. Mine.</p>
		</a>
		<a class="card" href={sectionUrl(base, 'blog')}>
			<span class="card-label">04</span>
			<h2>Sports blog</h2>
			<p>Fully convinced. Occasionally wrong.</p>
		</a>
		<a class="card" href={sectionUrl(base, 'photography')}>
			<span class="card-label">05</span>
			<h2>Photography</h2>
			<p>The world as I catch it.</p>
		</a>
	</section>
</Layout>

<style>
	.hero {
		margin-bottom: 2.5rem;
	}

	.grid {
		display: grid;
		gap: 1rem;
		grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
	}

	.card {
		display: block;
		padding: 1.35rem 1.25rem;
		border-radius: 10px;
		border: 1px solid var(--border);
		background: color-mix(in srgb, var(--surface) 88%, var(--bg));
		text-decoration: none;
		color: inherit;
		transition:
			border-color 0.2s ease,
			transform 0.2s ease,
			box-shadow 0.2s ease;
	}

	.card:hover {
		border-color: #000000;
		transform: translateY(-2px);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
	}

	.card:hover :global(h2) {
		color: var(--accent);
	}

	.card-label {
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		color: #4a4a4a;
		letter-spacing: 0.12em;
	}

	.card h2 {
		font-size: 1.2rem;
		margin: 0.5rem 0 0.35rem;
		color: var(--text);
		transition: color 0.2s ease;
	}

	.card p {
		font-size: 0.9375rem;
		margin: 0;
	}
</style>
