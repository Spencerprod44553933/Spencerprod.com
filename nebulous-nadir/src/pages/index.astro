---
import Layout from '../layouts/Layout.astro';
import { sectionUrl } from '../lib/paths';

const base = import.meta.env.BASE_URL;
---

<Layout title="Spencerprod" description="Portfolio — cyber projects, music, sports writing, and photography.">
	<section class="hero">
		<p class="eyebrow">Portfolio</p>
		<h1>Builds, sound, sport, and light.</h1>
		<p class="section-lede">
			Welcome. Use the tabs above to explore cyber work, music, a sports blog, and photography — each area has its own space.
		</p>
	</section>

	<section class="grid">
		<a class="card" href={sectionUrl(base, 'cyber')}>
			<span class="card-label">01</span>
			<h2>Cyber</h2>
			<p>Security, tooling, and technical projects.</p>
		</a>
		<a class="card" href={sectionUrl(base, 'music')}>
			<span class="card-label">02</span>
			<h2>Music</h2>
			<p>Releases, mixes, and what you are listening to or making.</p>
		</a>
		<a class="card" href={sectionUrl(base, 'blog')}>
			<span class="card-label">03</span>
			<h2>Blog</h2>
			<p>Sports writing and updates.</p>
		</a>
		<a class="card" href={sectionUrl(base, 'photography')}>
			<span class="card-label">04</span>
			<h2>Photo</h2>
			<p>Galleries and still work.</p>
		</a>
	</section>
</Layout>

<style>
	.hero {
		margin-bottom: 2.5rem;
	}

	.eyebrow {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		font-weight: 500;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--accent);
		margin: 0 0 0.75rem;
	}

	.grid {
		display: grid;
		gap: 1rem;
		grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
	}

	.card {
		display: block;
		padding: 1.35rem 1.25rem;
		border-radius: 10px;
		border: 1px solid var(--border);
		background: color-mix(in srgb, var(--surface) 88%, var(--bg));
		text-decoration: none;
		color: inherit;
		transition:
			border-color 0.2s ease,
			transform 0.2s ease,
			box-shadow 0.2s ease;
	}

	.card:hover {
		border-color: #000000;
		transform: translateY(-2px);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
	}

	.card:hover :global(h2) {
		color: var(--accent);
	}

	.card-label {
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		color: #4a4a4a;
		letter-spacing: 0.12em;
	}

	.card h2 {
		font-size: 1.2rem;
		margin: 0.5rem 0 0.35rem;
		color: var(--text);
		transition: color 0.2s ease;
	}

	.card p {
		font-size: 0.9375rem;
		margin: 0;
	}
</style>
