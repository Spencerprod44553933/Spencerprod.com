---
import LangToggle from './LangToggle.astro';
import { sectionUrl } from '../lib/paths';

const base = import.meta.env.BASE_URL;

const links = [
	{ href: sectionUrl(base, ''), labelEn: 'Home', labelEs: 'Inicio' },
	{ href: sectionUrl(base, 'cyber'), labelEn: 'Cyber', labelEs: 'Cyber' },
	{ href: sectionUrl(base, 'music'), labelEn: 'My Music', labelEs: 'Mi música' },
	{ href: sectionUrl(base, 'music/blog'), labelEn: 'Music blog', labelEs: 'Blog de música' },
	{ href: sectionUrl(base, 'blog'), labelEn: 'Sports blog', labelEs: 'Blog deportivo' },
	{ href: sectionUrl(base, 'photography'), labelEn: 'Photography', labelEs: 'Fotografía' },
] as const;

function normalizePath(pathname: string) {
	const x = pathname.replace(/\/$/, '');
	return x === '' ? '/' : x;
}

const currentPath = normalizePath(Astro.url.pathname);
const homePath = normalizePath(new URL(base, Astro.url).pathname);

/** Longest URL path wins so /music/blog/ does not also highlight /music/. */
const linksWithTargets = [...links]
	.map((link) => ({
		...link,
		target: normalizePath(new URL(link.href, Astro.url).pathname),
	}))
	.sort((a, b) => b.target.length - a.target.length);

const activeHref =
	linksWithTargets.find(({ target }) => {
		if (target === homePath) return currentPath === homePath;
		return currentPath === target || currentPath.startsWith(`${target}/`);
	})?.href ?? null;

function isActive(href: string) {
	return href === activeHref;
}
---

<header class="site-header">
	<div class="site-header-top">
		<a class="brand" href={base}>Spencerprod</a>
		<LangToggle />
	</div>
	<nav class="tabs" aria-label="Main">
		<ul>
			{
				links.map(({ href, labelEn, labelEs }) => (
					<li>
						<a href={href} class:list={['tab', { active: isActive(href) }]} aria-current={isActive(href) ? 'page' : undefined}>
							<span class="i18n-en">{labelEn}</span>
							<span class="i18n-es">{labelEs}</span>
						</a>
					</li>
				))
			}
		</ul>
	</nav>
</header>

<style>
	.site-header-top {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 1rem 1.25rem;
		width: 100%;
	}

	.site-header {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 1.25rem 1.75rem;
		padding: 1.15rem 1.75rem;
		border-bottom: 2px solid var(--border);
		background: color-mix(in srgb, var(--surface) 92%, transparent);
		backdrop-filter: blur(12px);
		position: sticky;
		top: 0;
		z-index: 50;
	}

	.brand {
		font-family: var(--font-display);
		font-weight: 800;
		font-size: clamp(1.35rem, 3.5vw, 1.75rem);
		letter-spacing: -0.03em;
		line-height: 1;
		color: var(--text);
		text-decoration: none;
	}

	.brand:hover {
		opacity: 0.65;
	}

	.tabs ul {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.35rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.tab {
		display: inline-block;
		padding: 0.55rem 1rem;
		border-radius: 8px;
		font-family: var(--font-display);
		font-size: clamp(1.125rem, 2.4vw, 1.375rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		line-height: 1.1;
		color: var(--text-muted);
		text-decoration: none;
		border: 2px solid transparent;
		transition:
			color 0.15s ease,
			background 0.15s ease,
			border-color 0.15s ease;
	}

	.tab:hover {
		color: var(--text);
		background: #ebebeb;
	}

	.tab.active {
		color: var(--bg);
		background: var(--accent);
		border-color: color-mix(in srgb, var(--accent) 70%, var(--text));
	}

	@media (max-width: 520px) {
		.site-header {
			flex-direction: column;
			align-items: stretch;
		}

		.site-header-top {
			flex-direction: column;
			align-items: stretch;
		}

		.tabs ul {
			justify-content: center;
		}
	}
</style>
