---
import SiteNav from '../components/SiteNav.astro';
import '../styles/placeholders.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Spencerprod',
	description = 'Portfolio — cyber, music, record opinions, sports writing, and photography.',
} = Astro.props;
const pageTitle = title === 'Spencerprod' ? title : `${title} · Spencerprod`;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
		<link rel="icon" href={`${base}favicon.ico`} />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,600;9..40,700&family=JetBrains+Mono:wght@400;500&family=Syne:wght@700;800&display=swap"
			rel="stylesheet"
		/>
		<title>{pageTitle}</title>
	</head>
	<body>
		<SiteNav />
		<main class="page-main">
			<slot />
		</main>
	</body>
</html>

<style is:global>
	:root {
		--bg: #ffffff;
		--surface: #f4f4f4;
		--border: #d9d9d9;
		--text: #000000;
		--text-muted: #1a1a1a;
		--accent: #000000;
		--accent-dim: color-mix(in srgb, var(--accent) 12%, var(--bg));
		--font-display: 'Syne', system-ui, sans-serif;
		--font-body: 'DM Sans', system-ui, sans-serif;
		--font-mono: 'JetBrains Mono', ui-monospace, monospace;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		min-height: 100vh;
		font-family: var(--font-body);
		font-size: 1.0625rem;
		line-height: 1.6;
		color: var(--text);
		background: var(--bg);
	}

	.page-main {
		max-width: 56rem;
		margin: 0 auto;
		padding: 2.5rem 1.5rem 4rem;
	}

	h1,
	h2,
	h3 {
		font-family: var(--font-display);
		letter-spacing: -0.03em;
		line-height: 1.15;
		color: var(--text);
	}

	h1 {
		font-size: clamp(2rem, 5vw, 2.75rem);
		font-weight: 800;
		margin: 0 0 1rem;
	}

	h2 {
		font-size: 1.35rem;
		font-weight: 700;
		margin: 2rem 0 0.75rem;
	}

	p {
		margin: 0 0 1rem;
		color: var(--text);
	}

	a {
		color: var(--accent);
	}

	a:hover {
		text-decoration: underline;
		text-underline-offset: 3px;
	}

	.section-lede {
		font-size: 1.125rem;
		max-width: 42ch;
	}
</style>
