# Copy to `.env` for local builds (never commit real keys).
# The fetch script reads process.env only — export vars before `npm run build`, e.g. `set -a && source .env && set +a`.
#
# Keys are optional: without them the build still pulls public data (YouTube channel scrape +
# innertube player dates; SoundCloud web client_id + api-v2 stream/users). Registered API keys
# are still recommended for stability and quotas.
#
# GitHub Actions: optional Secrets YOUTUBE_API_KEY, SOUNDCLOUD_CLIENT_ID; Variable YOUTUBE_CHANNEL_ID.

YOUTUBE_API_KEY=
# Channel uploads playlist is derived from UC… id (UU + rest). Override if needed.
YOUTUBE_CHANNEL_ID=

# Optional: official app at https://developers.soundcloud.com/ (uses api.soundcloud.com).
SOUNDCLOUD_CLIENT_ID=
